# S3 配置 (Garage S3 / AWS S3 兼容)
S3_ENDPOINT=https://s3.garfield.pp.ua
S3_REGION=auto
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET=garfield-ledger

# JWT 密钥 (请修改为随机的长字符串)
JWT_SECRET=change-this-to-a-random-secret-string

# ============================================
# AI 配置 — 支持 OpenAI 兼容 API 或 Gemini
# ============================================

# AI 提供商: "openai" 或 "gemini" (默认 gemini)
AI_PROVIDER=openai

# ---- OpenAI 兼容 API (AI_PROVIDER=openai 时必填) ----
# 标准 OpenAI: https://api.openai.com/v1
# OpenRouter:   https://openrouter.ai/api/v1
# Groq:         https://api.groq.com/openai/v1
# Together AI:  https://api.together.xyz/v1
# 任意兼容 OpenAI 格式的 API 都支持
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ---- Gemini (AI_PROVIDER=gemini 时必填) ----
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# 初始管理员账号 (仅首次部署用)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
